{
  "name": "bluesky-overlay",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "author": "Aricie",
  "description": "Bluesky desktop overlay — rolling timeline notifications",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron dist/main.js",
    "dev": "concurrently --kill-others \"vite\" \"tsc -p tsconfig.json -w\" \"wait-on http://localhost:5173 && electron dist/main.js\"",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@atproto/api": "^0.13.0",
    "framer-motion": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0",
    "typescript": "^5.3.0",
    "vite": "^6.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bluesky.overlay",
    "productName": "Bluesky Overlay",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bluesky Overlay"
    }
  }
}
